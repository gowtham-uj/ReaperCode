# OMP runtime state lives in this directory alongside the project config.
# Track the project config files; ignore the runtime SQLite DBs and
# session captures so they don't pollute diffs.
#
# Tracked (project config):
#   omp.project, models.yml, config.yml
#   themes/, tools/, commands/, prompts/, modules/, memories/, agents/, secrets.yml
# Ignored (runtime state):
#   *.db, *.db-shm, *.db-wal
#   sessions/, terminal-sessions/

# Live SQLite databases and their WAL/SHM sidecars.
*.db
*.db-shm
*.db-wal

# Session JSONL transcripts and terminal-sessions bookkeeping.
sessions/
terminal-sessions/

# Local crash/debug logs that may appear next to the agent DBs.
omp-crash.log
omp-debug.log
